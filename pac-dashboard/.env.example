# Supabase — https://supabase.com/dashboard/project/<project-ref>/settings/api
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# Proxy JustETF — CORS origin consentita per l'API serverless (es. https://yourdomain.com)
# Lascia vuoto in sviluppo locale; imposta l'URL di produzione in Vercel
ALLOWED_ORIGIN=

# Sentry — error monitoring (opzionale, PAC-67)
# https://sentry.io/settings/<org>/projects/<project>/keys/
VITE_SENTRY_DSN=
